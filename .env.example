# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

GEMINI_API_KEY=your-gemini-api-key-here

# Model choice for extraction/derivation. flash-lite-latest is the validated default
# (free tier, see docs/architecture.md ingestion step 2). gemini-pro-latest is available
# but has zero free-tier quota on a standard AI Studio key as of 2026-07 — requires billing.
MODEL=gemini-flash-lite-latest
